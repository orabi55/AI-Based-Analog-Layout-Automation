# ─────────────────────────────────────────────────────
#  API Keys — copy this file to .env and fill in yours
# ─────────────────────────────────────────────────────

# Google Gemini (primary — recommended)
GEMINI_API_KEY=

# Groq (free tier, fast — get key at https://console.groq.com)
GROQ_API_KEY=

# OpenAI (optional fallback)
OPENAI_API_KEY=

# DeepSeek (optional fallback)
DEEPSEEK_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=
